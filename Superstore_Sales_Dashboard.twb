      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.14uoi2c0yaijqs10bc3hz1764uo5].[pcto:sum:Profit:qk:2]&quot;' value='Profit %' />
          <alias key='&quot;[federated.14uoi2c0yaijqs10bc3hz1764uo5].[pcto:sum:Sales:qk:2]&quot;' value='Sales %' />
        </aliases>
      </column>
      <column caption='LY Profit' datatype='real' name='[CY Profit (copy)_0943434688606216]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{fixed :sum(if YEAR([Order Date]) = {MAX(YEAR([Order Date])- 1)}&#13;&#10;then [Profit]&#13;&#10;END&#13;&#10;)&#13;&#10;}' />
      </column>
      <column caption='Order Count' datatype='integer' name='[Calculation_0943434584576002]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Customer ID]:COUNTD([Order ID]) }' />
      </column>
      <column caption='Customer Group' datatype='string' name='[Calculation_0943434594361348]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Customer Name Set] then &quot;Top 50 Customers&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
      </column>
      <column caption='Max' datatype='integer' name='[Calculation_0943434685706245]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{MAX(YEAR([Order Date]))}' />
      </column>
      <column caption='CY Profit' datatype='real' name='[Calculation_0943434686824454]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{fixed :sum(if YEAR([Order Date]) = {MAX(YEAR([Order Date]))}&#13;&#10;then [Profit]&#13;&#10;END&#13;&#10;)&#13;&#10;}' />
      </column>
      <column caption='Last 12 Months' datatype='boolean' name='[Calculation_0943434689421321]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[Order Date])&gt;=&#13;&#10;DATEADD(&apos;month&apos;,-11,{MAX(DATETRUNC(&apos;month&apos;,[Order Date]))})' />
      </column>
      <column caption='DateAdd' datatype='datetime' name='[Calculation_0943434691022858]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEADD(&apos;month&apos;,-11,[Order Date])' />
      </column>
      <column caption='Change % YOY' datatype='real' name='[Calculation_0943434699251724]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='(SUM([Calculation_0943434686824454])-SUM([CY Profit (copy)_0943434688606216]))/SUM([CY Profit (copy)_0943434688606216])' />
      </column>
      <column caption='View' datatype='string' name='[Calculation_0943434707349517]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Region&quot; THEN [Region]&#13;&#10;    ELSEIF [Parameters].[Parameter 1] = &quot;Category&quot; THEN [Category]&#13;&#10;    ELSE [Sub-Category]&#13;&#10;END' />
      </column>
      <column caption='Metric' datatype='real' name='[Calculation_0943434717696014]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 2] = &quot;Sales&quot; THEN SUM([Sales])&#13;&#10;ELSEIF [Parameters].[Parameter 2] = &quot;Profit&quot; THEN SUM([Profit])&#13;&#10;ELSE COUNT([Order ID])&#13;&#10;END' />
      </column>
      <column caption='Profit Margin' datatype='real' name='[Calculation_0943434719842319]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_0943434721091600]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Order ID (Returns)])/COUNTD([Order ID])' />
      </column>
