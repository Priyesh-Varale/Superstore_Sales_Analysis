            <run bold='true' fontalignment='1'><![CDATA[<[federated.14uoi2c0yaijqs10bc3hz1764uo5].[sum:Calculation_0943434686824454:qk]>]]></run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#72b966' fontname='Times New Roman,serif'>▲</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Times New Roman,serif'><![CDATA[+<[federated.14uoi2c0yaijqs10bc3hz1764uo5].[usr:Calculation_0943434699251724:qk]> ]]></run>
            <run bold='true' fontalignment='1'>vs PY</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Orders (sample_-_superstore)' name='federated.14uoi2c0yaijqs10bc3hz1764uo5' />
          </datasources>
          <datasource-dependencies datasource='federated.14uoi2c0yaijqs10bc3hz1764uo5'>
            <column caption='LY Profit' datatype='real' name='[CY Profit (copy)_0943434688606216]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{fixed :sum(if YEAR([Order Date]) = {MAX(YEAR([Order Date])- 1)}&#13;&#10;then [Profit]&#13;&#10;END&#13;&#10;)&#13;&#10;}' />
            </column>
            <column caption='CY Profit' datatype='real' name='[Calculation_0943434686824454]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{fixed :sum(if YEAR([Order Date]) = {MAX(YEAR([Order Date]))}&#13;&#10;then [Profit]&#13;&#10;END&#13;&#10;)&#13;&#10;}' />
            </column>
            <column caption='Last 12 Months' datatype='boolean' name='[Calculation_0943434689421321]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[Order Date])&gt;=&#13;&#10;DATEADD(&apos;month&apos;,-11,{MAX(DATETRUNC(&apos;month&apos;,[Order Date]))})' />
            </column>
            <column caption='Change % YOY' datatype='real' name='[Calculation_0943434699251724]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='(SUM([Calculation_0943434686824454])-SUM([CY Profit (copy)_0943434688606216]))/SUM([CY Profit (copy)_0943434688606216])' />
            </column>
            <column datatype='date' name='[Order Date]' role='dimension' type='ordinal' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column caption='Region1' datatype='string' name='[Region]' role='dimension' type='nominal' />
            <column-instance column='[Order Date]' derivation='Month' name='[mn:Order Date:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Calculation_0943434689421321]' derivation='None' name='[none:Calculation_0943434689421321:nk]' pivot='key' type='nominal' />
            <column-instance column='[Region]' derivation='None' name='[none:Region:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0943434686824454]' derivation='Sum' name='[sum:Calculation_0943434686824454:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Profit]' derivation='Sum' name='[sum:Profit:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0943434699251724]' derivation='User' name='[usr:Calculation_0943434699251724:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Order Date]' derivation='Year' name='[yr:Order Date:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.14uoi2c0yaijqs10bc3hz1764uo5].[none:Calculation_0943434689421321:nk]'>
            <groupfilter function='member' level='[none:Calculation_0943434689421321:nk]' member='true' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
